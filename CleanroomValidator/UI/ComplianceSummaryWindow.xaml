<Window x:Class="CleanroomValidator.UI.ComplianceSummaryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cleanroom Compliance Check — Summary"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="StatusCompliant" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#2E7D32"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="StatusPartial" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F57C00"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="StatusFail" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C62828"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Level grouping style -->
        <Style x:Key="LevelGroupStyle" TargetType="GroupItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GroupItem">
                        <Expander IsExpanded="True" Background="#E8E8E8" Margin="0,3,0,0">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="12" Margin="5,2"/>
                                    <TextBlock Text="{Binding ItemCount, StringFormat=' ({0} spaces)'}" 
                                               Foreground="#666" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Expander.Header>
                            <ItemsPresenter/>
                        </Expander>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Cleanroom Compliance Check" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <CheckBox x:Name="UseLinkedModelCheckbox" 
                      Content="Use Linked Mechanical Model:" 
                      VerticalAlignment="Center" 
                      Margin="30,0,10,0"
                      Checked="UseLinkedModelCheckbox_Changed"
                      Unchecked="UseLinkedModelCheckbox_Changed"/>
            <ComboBox x:Name="LinkedModelComboBox" 
                      Width="200" 
                      IsEnabled="False"
                      SelectionChanged="LinkedModelComboBox_SelectionChanged"/>
        </StackPanel>

        <!-- Summary Stats -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Summary: " FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="CompliantCount" Style="{StaticResource StatusCompliant}" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Text=" | " VerticalAlignment="Center"/>
                <TextBlock x:Name="PartialCount" Style="{StaticResource StatusPartial}" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Text=" | " VerticalAlignment="Center"/>
                <TextBlock x:Name="FailCount" Style="{StaticResource StatusFail}" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </Border>

        <!-- Main Data Grid -->
        <DataGrid x:Name="ResultsGrid" 
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="ResultsGrid_SelectionChanged"
                  Background="White"
                  BorderBrush="#DDD"
                  BorderThickness="1"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="#EEE"
                  RowHeight="30"
                  ColumnHeaderHeight="35">
            <DataGrid.GroupStyle>
                <GroupStyle ContainerStyle="{StaticResource LevelGroupStyle}">
                    <GroupStyle.Panel>
                        <ItemsPanelTemplate>
                            <DataGridRowsPresenter/>
                        </ItemsPanelTemplate>
                    </GroupStyle.Panel>
                </GroupStyle>
            </DataGrid.GroupStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Space" Binding="{Binding RoomName}" Width="*"/>
                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#888"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Class" Binding="{Binding CleanlinessClass}" Width="70"/>
                <DataGridTextColumn Header="Volume (CF)" Binding="{Binding VolumeCubicFeet, StringFormat=N0}" Width="90"/>
                <DataGridTextColumn Header="CFM" Binding="{Binding ActualSupplyCfm, StringFormat=N0}" Width="70"/>
                <!-- ACH Column with color coding -->
                <DataGridTemplateColumn Header="ACH" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ActualAch, StringFormat=N1}" HorizontalAlignment="Right" Padding="0,0,5,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding AchMeetsRequirement}" Value="False">
                                                <Setter Property="Background" Value="#FFCDD2"/>
                                                <Setter Property="Foreground" Value="#C62828"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- ACH Required Column -->
                <DataGridTextColumn Header="ACH Req" Binding="{Binding RequiredAch}" Width="65"/>
                <!-- Recovery Time Column -->
                <DataGridTextColumn Header="Recovery (min)" Binding="{Binding RecoveryTimeMinutes, StringFormat=N1}" Width="95"/>
                <DataGridTextColumn Header="Pressure" Binding="{Binding ActualPressure, StringFormat=N1}" Width="70"/>
                <DataGridTemplateColumn Header="Status" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding StatusIcon}" 
                                       HorizontalAlignment="Center"
                                       FontSize="16">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OverallStatus}" Value="Compliant">
                                                <Setter Property="Foreground" Value="#2E7D32"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OverallStatus}" Value="PartialCompliance">
                                                <Setter Property="Foreground" Value="#F57C00"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding OverallStatus}" Value="NonCompliant">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Detail Panel -->
        <Border Grid.Row="3" Background="White" CornerRadius="5" Padding="15" Margin="0,15,0,0">
            <StackPanel>
                <TextBlock Text="Check Details" Style="{StaticResource HeaderStyle}"/>
                <DataGrid x:Name="DetailsGrid"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          MaxHeight="150"
                          Background="White"
                          BorderThickness="0"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          RowHeight="25">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Check" Binding="{Binding CheckName}" Width="*"/>
                        <DataGridTextColumn Header="Required" Binding="{Binding Required}" Width="120"/>
                        <DataGridTextColumn Header="Actual" Binding="{Binding Actual}" Width="120"/>
                        <DataGridTemplateColumn Header="Result" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="—"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Compliant">
                                                        <Setter Property="Text" Value="✓"/>
                                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="PartialCompliance">
                                                        <Setter Property="Text" Value="⚠"/>
                                                        <Setter Property="Foreground" Value="#F57C00"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="NonCompliant">
                                                        <Setter Property="Text" Value="✗"/>
                                                        <Setter Property="Foreground" Value="#C62828"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="ExportButton" Content="Export to CSV" Width="100" Height="30" Margin="0,0,10,0" Click="ExportButton_Click"/>
            <Button x:Name="RefreshButton" Content="Refresh" Width="80" Height="30" Margin="0,0,10,0" Click="RefreshButton_Click"/>
            <Button x:Name="CloseButton" Content="Close" Width="80" Height="30" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
